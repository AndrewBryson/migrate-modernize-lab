          "appSettings": [
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId('Microsoft.Insights/components', format('ai{0}', parameters('resourceToken'))), '2020-02-02').ConnectionString]"
